<Page x:Class="WpfForrat.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfForrat.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница входа"
      Background="White">

    <Grid>
        <StackPanel Width="200" VerticalAlignment="Center">
            <Image Source="/Images/Icon.png" Width="100"/>
            <TextBlock Text="Вход" FontSize="20" Margin="0 8 0 0"/>
            <TextBlock Text="Логин"/>
            <TextBox Text="{Binding Login}"/>
            <TextBlock Text="Пароль"/>
            <TextBox Text="{Binding Password}"/>
            <Button Content="Войти" Click="VhodPolzovatel" Margin="0 10 0 0"/>
            <Button Content="Войти как гость" Click="VhodGost" Margin="0 10 0 0"/>
        </StackPanel >
    </Grid>
</Page>
