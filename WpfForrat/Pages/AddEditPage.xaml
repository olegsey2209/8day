<Page x:Class="WpfForrat.Pages.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfForrat.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="850" d:DesignWidth="800"
      Title="Страница добавления/редактирования"
      Background="white">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Button Content="Назад" Click="BackButton" Grid.Row="0" Width="100" HorizontalAlignment="Left"/>
        <StackPanel Grid.Row="1" Grid.Column="0" Width="400" VerticalAlignment="Center">

            <TextBlock Text="Добавление / редактирование товара" FontSize="20" Margin="0 8 0 0"/>
            <TextBlock x:Name="IdTextBlock" Margin="0 8 0 0">
                 <Run Text="ID товара:" />
                 <Run Text="{Binding Tovar.IdTovar}" />     
            </TextBlock>

            <TextBlock Text="Артикул" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.Articul, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Наименование товара" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.NameTovar, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Категория товара" Margin="0 8 0 0"/>
            <ComboBox ItemsSource="{Binding Categories}"
              SelectedValue="{Binding Tovar.IdCategory}"
              SelectedValuePath="IdCategory"
              DisplayMemberPath="Category"
              Margin="0 8 0 0"/>

            <TextBlock Text="Описание товара" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.Opisanie, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Цена" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.Money, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Количество на складе" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.KolSklad, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Действующая скидка" Margin="0 8 0 0"/>
            <TextBox Text="{Binding Tovar.Sale, UpdateSourceTrigger=PropertyChanged}" Margin="0 8 0 0"/>

            <TextBlock Text="Единица измерения" Margin="0 8 0 0"/>
            <ComboBox ItemsSource="{Binding EdIzms}"
              SelectedValue="{Binding Tovar.IdEdIzm}"
              SelectedValuePath="IdEdIzm"
              DisplayMemberPath="EdIzm1"
              Margin="0 8 0 0"/>

            <TextBlock Text="Производитель" Margin="0 8 0 0"/>
            <ComboBox ItemsSource="{Binding Proizvoditeli}"
              SelectedValue="{Binding Tovar.IdProizvod}"
              SelectedValuePath="IdProizvod"
              DisplayMemberPath="Name"
              Margin="0 8 0 0"/>

            <TextBlock Text="Поставщик" Margin="0 8 0 0"/>
            <ComboBox ItemsSource="{Binding Postavshiki}"
              SelectedValue="{Binding Tovar.IdPost}"
              SelectedValuePath="IdPost"
              DisplayMemberPath="Name"
              Margin="0 8 0 0"/>
    
            <Button Content="Сохранить" Margin="0 12 0 0" Click="SaveButton"/>
    
        </StackPanel>
        <StackPanel VerticalAlignment="Center" Orientation="Vertical" Grid.Column="1" Grid.Row="1">
            <Image x:Name="ProductImage" Source="{Binding Tovar.Fhoto }"  Width="300" Height="200"/>
            <Button Content="Выбрать фото" Click="ChoosePhotoButton" Width="150"/>
        </StackPanel>
    </Grid>
</Page>
