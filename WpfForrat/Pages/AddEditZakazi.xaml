<Page x:Class="WpfForrat.Pages.AddEditZakazi"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfForrat.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница добавления и редактирования заказов"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Content="Назад" Click="BackButton" Width="150" HorizontalAlignment="Left"/>
        <StackPanel Grid.Row="1" Width="400">
            <TextBlock Text="Добавление / редактирование заказа" FontSize="20" Margin="0 8 0 0"/>
            <TextBlock  Margin="0 8 0 0">
                <Run Text="Артикул заказа:" />
                <Run Text="{Binding Zakaz.IdZakaz}" />
            </TextBlock>
            <TextBlock Text="Клиент" Margin="0 8 0 0"/>
            <ComboBox ItemsSource="{Binding Users}" SelectedValue="{Binding Zakaz.IdUser}" SelectedValuePath="IdUser" DisplayMemberPath="Fio" Margin="0 8 0 0"/>
            <TextBlock Text="Статус заказа"  Margin="0 8 0 0"/>
            <ComboBox  ItemsSource="{Binding Statuses}" SelectedValue="{Binding Zakaz.IdStatus}" SelectedValuePath="IdStatus" DisplayMemberPath="Status1" Margin="0 8 0 0"/>
            <TextBlock Text="Адрес пункта выдачи" Margin="0 8 0 0"/>
            <ComboBox  ItemsSource="{Binding PunktVidachis}" SelectedValue="{Binding Zakaz.IdAdres}" SelectedValuePath="IdPunkta" DisplayMemberPath="Adres" Margin="0 8 0 0"/>
            <TextBlock Text="Дата заказа" Margin="0 8 0 0"/>
            <DatePicker SelectedDate="{Binding DateZakazPicker}" Margin="0 8 0 0"/>
            <TextBlock Text="Дата выдачи" Margin="0 8 0 0"/>
            <DatePicker SelectedDate="{Binding DateDostavPicker}" Margin="0 8 0 0"/>
            <Button Width="150"  Margin="0 8 0 0" Content="Сохранить" Click="SaveClick"/>

        </StackPanel>
    </Grid>
</Page>
