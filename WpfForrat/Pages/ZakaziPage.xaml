<Page x:Class="WpfForrat.Pages.ZakaziPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfForrat.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="Страница заказов"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
           <Grid.ColumnDefinitions>
             <ColumnDefinition Width="*"/>
             <ColumnDefinition Width="*"/>
           </Grid.ColumnDefinitions>
            <Button Content="Назад" Grid.Column="0" Width="150" HorizontalAlignment="Left" Click="BackClick"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding CurrentUser.IdRole, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter='1_'}">
                <Button Content="Добавить" Width="150" HorizontalAlignment="Left" Click="AddClick"/>
                <Button Content="Удалить" Margin="10 0 0 0" Width="150" HorizontalAlignment="Left" Click="DeleteClick"/>
            </StackPanel>
        </Grid>
        <ListView Grid.Row="1" x:Name="ZakazListView" ItemsSource="{Binding Zakazs}" MouseDoubleClick="ZakazListView_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="Bold">
                                    <Run Text="Артикул заказа:"/>
                                    <Run Text="{Binding IdZakaz}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Статус заказа"/>
                                    <Run Text="{Binding IdStatusNavigation.Status1}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Адрес пункта выдачи"/>
                                    <Run Text="{Binding IdAdresNavigation.Adres}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Дата заказа"/>
                                    <Run Text="{Binding DateZakaz, StringFormat={}{0:dd.MM.yyyy}}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Run Text="Дата доставки"/>
                                    <Run Text="{Binding DateDostav, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
    </Grid>
</Page>
